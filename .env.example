SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///store.db
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=True
FLASK_DEBUG=False

# ── Peach Payments ────────────────────────────────────────────
# South Africa's Peach Payments hosted checkout integration.
# Add your credentials from the Peach Payments dashboard.
# Set PEACH_SANDBOX=False in production.
PEACH_ENTITY_ID=your-entity-id-here
PEACH_AUTH_TOKEN=your-auth-token-here
PEACH_SANDBOX=True

# ── Yoco (Online Card Payments) ───────────────────────────────
# South African card payment gateway.
# Get your keys at https://business.yoco.com/ → Developers → API Keys.
# Use sk_test_xxx for sandbox, sk_live_xxx for live.
# YOCO_WEBHOOK_SECRET: copy from Yoco dashboard → Developers → Webhooks.
YOCO_SECRET_KEY=sk_test_your-yoco-secret-key-here
YOCO_WEBHOOK_SECRET=your-yoco-webhook-secret-here

# ── Ozow (Instant EFT) ───────────────────────────────────────
# Instant EFT gateway — no card needed.
# Get credentials at https://merchant.ozow.com/ → Settings → Site.
OZOW_SITE_CODE=your-ozow-site-code-here
OZOW_PRIVATE_KEY=your-ozow-private-key-here
OZOW_SANDBOX=True

# Flask-Mail — kept for legacy compatibility; transactional email uses SES
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
MAIL_ADMIN=admin@yourdomain.com

# ── Amazon SES (Transactional Email) ─────────────────────────
# Used for: order confirmations, password resets, shipping updates,
# contact form notifications, account verification.
# Create an IAM user with AmazonSESFullAccess and verify your domain/email in SES.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SES_REGION=us-east-1
SES_FROM_EMAIL=no-reply@yourdomain.com
SES_FROM_NAME=The Bodhi Tree

# ── Klaviyo (Marketing / Newsletter) ─────────────────────────
# Handles newsletters, promotions, branded campaigns, automations.
# Go to Klaviyo → Account → Settings → API Keys to generate keys.
# KLAVIYO_LIST_ID: the ID of the list subscribers should be added to.
KLAVIYO_PRIVATE_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLAVIYO_LIST_ID=XXXXXX

# Mistral AI — for the Bodhi AI guide orb
# Get your key at https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key-here
